# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
dist/
build/
venv/
.venv/

# Heavy data dirs (downloaded, generated, or symlinked during local dev).
# Whole path is ignored — covers real dirs, symlinks, and contents alike.
# Pipeline scripts os.makedirs() what they need; no .gitkeep required.
src/data/original-datasets
src/data/experiment-datasets
src/data/vector-store

# Experiment results (generated by pipeline or downloaded from Zenodo).
src/experiments/results

# Analysis outputs (generated by notebook)
analysis/intermediate/**
!analysis/intermediate/.gitkeep
analysis/figures/**
!analysis/figures/.gitkeep

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.log
*.out
*.fls
*.fdb_latexmk
*.synctex.gz

# OS / IDE
.DS_Store
.vscode/
.idea/
.cursor/
.logfire/

# Secrets
.env
